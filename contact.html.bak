<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script>
tailwind.config={theme:{extend:{colors:{'sidewayz-dark':'#0a0a0a','sidewayz-darker':'#050505','copper':'#B87333','copper-light':'#D4925A','neon':'#00F5D4','neon-pink':'#FF006E','neon-purple':'#8338EC'},fontFamily:{'display':['Orbitron','sans-serif'],'body':['Inter','sans-serif'],'mono':['JetBrains Mono','monospace']}}}};
</script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{margin:0;padding:0;background:#0a0a0a;color:#fff;font-family:'Inter',sans-serif;overflow-x:hidden}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:#0a0a0a}
::-webkit-scrollbar-thumb{background:#B87333;border-radius:3px}
.nav-blur{backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px)}
.text-gradient{background:linear-gradient(135deg,#B87333 0%,#D4925A 50%,#00F5D4 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.magnetic-btn{position:relative;overflow:hidden;transition:all 0.3s ease}
.magnetic-btn::before{content:'';position:absolute;top:50%;left:50%;width:0;height:0;background:radial-gradient(circle,rgba(0,245,212,0.3) 0%,transparent 70%);transform:translate(-50%,-50%);transition:width 0.6s ease,height 0.6s ease}
.magnetic-btn:hover::before{width:400px;height:400px}
</style>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Sidewayz 8 Solutions",
  "url": "https://sidewayz8solutions.com/contact.html",
  "mainEntity": {
    "@type": "Organization",
    "name": "Sidewayz 8 Solutions",
    "email": "benjamin@sidewayz8solutions.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "New Orleans",
      "addressRegion": "LA",
      "addressCountry": "US"
    }
  }
}
</script>
</head>
<body class="bg-sidewayz-dark text-white antialiased">
<nav class="fixed top-0 left-0 w-full z-50 nav-blur bg-sidewayz-dark/80 border-b border-white/5">
<div class="w-full px-6 lg:px-12 py-4 flex justify-between items-center">
<a href="index.html" class="font-display font-bold text-xl tracking-wider text-white hover:text-copper transition-colors">SIDEWAYZ<span class="text-copper">8</span></a>
<div class="hidden md:flex items-center gap-8">
<a href="index.html#products" class="text-sm font-medium text-white/70 hover:text-copper transition-colors">Products</a>
<a href="index.html#services" class="text-sm font-medium text-white/70 hover:text-copper transition-colors">Services</a>
<a href="index.html#about" class="text-sm font-medium text-white/70 hover:text-copper transition-colors">About</a>
<a href="articles/" class="text-sm font-medium text-white/70 hover:text-copper transition-colors">Articles</a>
<a href="contact.html" class="px-5 py-2 bg-copper text-sidewayz-dark rounded-full text-sm font-medium font-display hover:bg-copper-light transition-all">Contact</a>
</div>
</div>
</nav>

<main>
<section class="relative w-full pt-32 pb-24 lg:pb-32 overflow-hidden">
<div class="absolute inset-0 bg-gradient-to-b from-sidewayz-dark via-sidewayz-darker to-sidewayz-dark"></div>
<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-copper/5 rounded-full blur-3xl pointer-events-none"></div>
<div class="relative z-10 w-full px-6 lg:px-12">
<div class="max-w-6xl mx-auto">
<nav class="flex items-center gap-2 text-sm text-white/40 mb-8" aria-label="Breadcrumb">
<a href="index.html" class="hover:text-copper transition-colors">Home</a>
<span>/</span>
<span class="text-copper">Contact</span>
</nav>
<div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
<div>
<span class="text-copper text-sm font-mono tracking-[0.3em] uppercase mb-6 block">Get In Touch</span>
<h1 class="font-display font-black text-5xl sm:text-6xl lg:text-7xl text-white mb-8 leading-[0.95]">LET'S TALK<br/><span class="text-gradient">BUSINESS</span></h1>
<p class="text-lg text-white/60 leading-relaxed mb-12">Ready to build something extraordinary? Whether you need AI-powered SaaS development, workflow automation, or a complete digital rebrand — we're here to turn your vision into reality.</p>
<div class="space-y-8">
<div class="flex items-start gap-4">
<div class="w-12 h-12 rounded-xl bg-copper/20 flex items-center justify-center flex-shrink-0">
<svg class="w-6 h-6 text-copper" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
</div>
<div>
<h3 class="font-display font-bold text-white mb-1">Email</h3>
<a href="mailto:benjamin@sidewayz8solutions.com" class="text-white/60 hover:text-copper transition-colors">benjamin@sidewayz8solutions.com</a>
</div>
</div>
<div class="flex items-start gap-4">
<div class="w-12 h-12 rounded-xl bg-neon/20 flex items-center justify-center flex-shrink-0">
<svg class="w-6 h-6 text-neon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
</div>
<div>
<h3 class="font-display font-bold text-white mb-1">Location</h3>
<p class="text-white/60">New Orleans, Louisiana<br/><span class="text-sm text-white/40">United States</span></p>
</div>
</div>
<div class="flex items-start gap-4">
<div class="w-12 h-12 rounded-xl bg-neon-purple/20 flex items-center justify-center flex-shrink-0">
<svg class="w-6 h-6 text-neon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
</div>
<div>
<h3 class="font-display font-bold text-white mb-1">Social</h3>
<div class="flex gap-4">
<a href="https://linkedin.com/in/sidewayz8" target="_blank" rel="noopener" class="text-white/60 hover:text-copper transition-colors">LinkedIn</a>
<a href="#" class="text-white/60 hover:text-copper transition-colors">Twitter</a>
<a href="#" class="text-white/60 hover:text-copper transition-colors">GitHub</a>
</div>
</div>
</div>
</div>
</div>
<div class="relative">
<div class="relative p-8 lg:p-10 bg-white/[0.02] border border-white/10 rounded-3xl">
<div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-copper/5 to-transparent rounded-3xl pointer-events-none"></div>
<div class="relative z-10">
<h2 class="font-display font-bold text-2xl text-white mb-2">Send a Message</h2>
<p class="text-white/50 text-sm mb-8">Tell us about your project and we'll get back within 24 hours.</p>
<form action="mailto:benjamin@sidewayz8solutions.com" method="post" enctype="text/plain" class="space-y-6">
<div class="grid sm:grid-cols-2 gap-6">
<div>
<label for="name" class="block text-sm font-medium text-white/70 mb-2">Name</label>
<input type="text" id="name" name="name" required class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-copper/50 transition-colors" placeholder="Your name">
</div>
<div>
<label for="email" class="block text-sm font-medium text-white/70 mb-2">Email</label>
<input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-copper/50 transition-colors" placeholder="you@company.com">
</div>
</div>
<div>
<label for="service" class="block text-sm font-medium text-white/70 mb-2">Service Interest</label>
<select id="service" name="service" class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white focus:outline-none focus:border-copper/50 transition-colors appearance-none">
<option value="" class="bg-sidewayz-dark">Select a service</option>
<option value="ai-saas" class="bg-sidewayz-dark">AI SaaS Development</option>
<option value="automation" class="bg-sidewayz-dark">AI Automation</option>
<option value="branding" class="bg-sidewayz-dark">AI Branding</option>
<option value="consulting" class="bg-sidewayz-dark">AI Consulting</option>
<option value="other" class="bg-sidewayz-dark">Other</option>
</select>
</div>
<div>
<label for="message" class="block text-sm font-medium text-white/70 mb-2">Message</label>
<textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-copper/50 transition-colors resize-none" placeholder="Tell us about your project..."></textarea>
</div>
<button type="submit" class="magnetic-btn w-full px-8 py-4 bg-copper text-sidewayz-dark font-display font-bold text-sm tracking-wider rounded-full hover:bg-copper-light transition-all relative z-10">SEND MESSAGE</button>
</form>
</div>
</div>
</div>
</div>
</div>
</div>
</section>
</main>

<footer class="relative w-full py-12 border-t border-white/5">
<div class="w-full px-6 lg:px-12">
<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
<div class="font-display font-bold text-xl tracking-wider text-white">SIDEWAYZ<span class="text-copper">8</span></div>
