<meta name="geo.region" content="US-LA">
<meta name="geo.placename" content="New Orleans">
<link rel="canonical" href="https://sidewayz8solutions.com/">
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script>
tailwind.config={theme:{extend:{colors:{'sidewayz-dark':'#0a0a0a','sidewayz-darker':'#050505','copper':'#B87333','copper-light':'#D4925A','neon':'#00F5D4','neon-pink':'#FF006E','neon-purple':'#8338EC'},fontFamily:{'display':['Orbitron','sans-serif'],'body':['Inter','sans-serif'],'accent':['Playfair Display','serif'],'mono':['JetBrains Mono','monospace']}}}};
</script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{margin:0;padding:0;background:#0a0a0a;color:#fff;font-family:'Inter',sans-serif;overflow-x:hidden}
#preloader{position:fixed;inset:0;background:#050505;z-index:10000;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:2rem}
.preloader-text{font-family:'Orbitron',sans-serif;font-size:1.5rem;font-weight:900;color:#B87333;letter-spacing:0.2em}
.preloader-bar{width:200px;height:2px;background:rgba(255,255,255,0.1);border-radius:2px;overflow:hidden}
.preloader-bar-fill{width:0%;height:100%;background:linear-gradient(90deg,#B87333,#00F5D4);transition:width 0.3s ease}
.preloader-counter{font-family:'JetBrains Mono',monospace;font-size:0.875rem;color:rgba(255,255,255,0.4)}
.cursor{position:fixed;width:12px;height:12px;background:#B87333;border-radius:50%;pointer-events:none;z-index:9999;mix-blend-mode:difference;transition:transform 0.1s ease,width 0.2s ease,height 0.2s ease}
.cursor-follower{position:fixed;width:40px;height:40px;border:1px solid rgba(184,115,51,0.4);border-radius:50%;pointer-events:none;z-index:9998;transition:transform 0.15s ease,width 0.3s ease,height 0.3s ease,border-color 0.3s ease}
.cursor.hover{transform:scale(2.5);background:rgba(0,245,212,0.8)}
.cursor-follower.hover{width:60px;height:60px;border-color:rgba(0,245,212,0.6)}
.cursor.click{transform:scale(0.5)}
.grain{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9990;opacity:0.04;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E")}
#hero-canvas{position:absolute;top:0;left:0;width:100%;height:100%;z-index:0}
.text-gradient{background:linear-gradient(135deg,#B87333 0%,#D4925A 50%,#00F5D4 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;background-size:200% 200%;animation:gradient 6s ease infinite}
.text-copper-glow{text-shadow:0 0 40px rgba(184,115,51,0.5),0 0 80px rgba(184,115,51,0.3),0 0 120px rgba(184,115,51,0.1)}
.tilt-card{transform-style:preserve-3d;perspective:1000px;transition:transform 0.1s ease-out}
.tilt-card-inner{transform-style:preserve-3d;transition:transform 0.6s cubic-bezier(0.4,0,0.2,1)}
.tilt-card:hover .tilt-card-inner{transform:translateZ(30px)}
.tilt-card-shine{position:absolute;inset:0;background:radial-gradient(circle at var(--mouse-x,50%) var(--mouse-y,50%),rgba(255,255,255,0.12) 0%,transparent 60%);opacity:0;transition:opacity 0.3s ease;pointer-events:none;border-radius:inherit}
.tilt-card:hover .tilt-card-shine{opacity:1}
.magnetic-btn{position:relative;overflow:hidden;transition:all 0.3s ease}
.magnetic-btn::before{content:'';position:absolute;top:50%;left:50%;width:0;height:0;background:radial-gradient(circle,rgba(0,245,212,0.3) 0%,transparent 70%);transform:translate(-50%,-50%);transition:width 0.6s ease,height 0.6s ease}
.magnetic-btn:hover::before{width:400px;height:400px}
.portfolio-item{overflow:hidden;position:relative}
.portfolio-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,10,0.95) 0%,rgba(10,10,10,0.4) 50%,transparent 100%);opacity:0;transition:opacity 0.5s ease;display:flex;flex-direction:column;justify-content:flex-end;padding:2rem}
.portfolio-item:hover .portfolio-overlay{opacity:1}
.nav-blur{backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px)}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:#0a0a0a}
::-webkit-scrollbar-thumb{background:#B87333;border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:#D4925A}
.reveal-up{opacity:0;transform:translateY(60px)}
.reveal-left{opacity:0;transform:translateX(-60px)}
.reveal-right{opacity:0;transform:translateX(60px)}
.reveal-scale{opacity:0;transform:scale(0.85)}
.section-line{height:1px;background:linear-gradient(90deg,transparent,rgba(184,115,51,0.4),transparent)}
.product-badge{position:absolute;top:-1px;right:-1px;padding:0.5rem 1rem;font-size:0.625rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;border-bottom-left-radius:1rem;z-index:20;-webkit-backface-visibility:hidden;backface-visibility:hidden}
#scroll-progress{position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,#B87333,#00F5D4);z-index:9999;width:0%;transition:width 0.1s linear}
@media (pointer:coarse){body{cursor:auto}.cursor,.cursor-follower{display:none}}
.service-panel{position:relative;overflow:hidden}
.service-panel::after{content:'';position:absolute;bottom:0;left:0;width:100%;height:2px;background:linear-gradient(90deg,#B87333,#00F5D4);transform:scaleX(0);transform-origin:left;transition:transform 0.5s cubic-bezier(0.4,0,0.2,1)}
.service-panel:hover::after{transform:scaleX(1)}
.service-panel .service-details{max-height:0;overflow:hidden;transition:max-height 0.5s cubic-bezier(0.4,0,0.2,1),opacity 0.3s ease;opacity:0}
.service-panel:hover .service-details{max-height:300px;opacity:1}
@keyframes gradient{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
@keyframes float{0%,100%{transform:translateY(0px)}50%{transform:translateY(-20px)}}
.flip-card{perspective:1000px;cursor:pointer;height:100%}
.flip-card-inner{position:relative;width:100%;height:100%;transition:transform 0.8s cubic-bezier(0.4,0,0.2,1);transform-style:preserve-3d}
.flip-card.flipped .flip-card-inner{transform:rotateY(180deg)}
.flip-card-front,.flip-card-back{position:absolute;inset:0;width:100%;height:100%;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:1rem;overflow:hidden}
.flip-card-front{transform:rotateY(0deg) translateZ(1px);background:rgba(255,255,255,0.03);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.1)}
.flip-card-back{transform:rotateY(180deg) translateZ(1px);background:linear-gradient(135deg,rgba(184,115,51,0.15),rgba(0,245,212,0.08));border:1px solid rgba(184,115,51,0.3);display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:1.5rem;gap:1.5rem}
.flip-hint{position:absolute;bottom:1rem;left:50%;transform:translateX(-50%);font-size:0.625rem;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.3);transition:color 0.3s ease;-webkit-backface-visibility:hidden;backface-visibility:hidden}
.flip-card:hover .flip-hint{color:rgba(184,115,51,0.8)}
</style>
